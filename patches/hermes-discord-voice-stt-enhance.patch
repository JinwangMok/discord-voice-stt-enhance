+    def _buffer_has_speech_characteristics(self, pcm_data: bytes) -> bool:
+        """Return whether a completed PCM buffer looks speech-like enough for STT."""
+        if len(pcm_data) < 4:
+            return False
+
+        rms, peak = self._pcm_level_stats(pcm_data)
+        if peak < self.MIN_BUFFER_PEAK:
+            return False
+        if rms >= self.MIN_BUFFER_RMS:
+            return True
+
+        frame_bytes = int(self.SAMPLE_RATE * self.CHANNELS * 2 * 0.02)
+        if frame_bytes <= 0:
+            return False
+
+        voiced_frames = 0
+        total_frames = 0
+        for start in range(0, len(pcm_data), frame_bytes):
+            frame = pcm_data[start:start + frame_bytes]
+            if len(frame) < 4:
+                continue
+            total_frames += 1
+            frame_rms, _ = self._pcm_level_stats(frame)
+            if frame_rms >= self.VOICED_FRAME_RMS:
+                voiced_frames += 1
+
+        if total_frames == 0:
+            return False
+        return (voiced_frames / total_frames) >= self.MIN_VOICED_FRAME_RATIO
+
+    @staticmethod
+    def _pcm_level_stats(pcm_data: bytes) -> tuple[float, int]:
+        """Return RMS and peak amplitude for signed 16-bit PCM."""
+        usable = len(pcm_data) - (len(pcm_data) % 2)
+        if usable < 2:
+            return 0.0, 0
+
+        samples = array("h")
+        samples.frombytes(pcm_data[:usable])
+        if not samples:
+            return 0.0, 0
+
+        peak = 0
+        total = 0
+        for sample in samples:
+            magnitude = abs(int(sample))
+            if magnitude > peak:
+                peak = magnitude
+            total += magnitude * magnitude
+
+        rms = (total / len(samples)) ** 0.5
+        return rms, peak
+
